<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:uxap="sap.uxap">
    <uxap:ObjectPageLayout id="ObjectPageLayout" upperCaseAnchorBar="false">
        <uxap:sections>
            <uxap:ObjectPageSection titleUppercase="false" title="General Information">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection >
                        <f:Form width="100%">
                            <f:layout>
                                <f:ColumnLayout columnsM="2" columnsL="3" columnsXL="4"/>
                            </f:layout>
                            <f:formContainers>
                                <f:FormContainer >
                                    <f:formElements>
                                        <f:FormElement label="BP Request Type">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/ZBTPRN}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="BP Type">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/ZBTTYP}"/>
                                            </f:fields>
                                        </f:FormElement>
                                    </f:formElements>
                                </f:FormContainer >
                            </f:formContainers>
                            <f:formContainers>
                                <f:FormContainer >
                                    <f:formElements>
                                        <f:FormElement label="Business Partner">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/PARTNER}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="Blocked?">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/BUSINESSPARTNERISBLOCKED}"/>
                                            </f:fields>
                                        </f:FormElement>
                                    </f:formElements>
                                </f:FormContainer >
                            </f:formContainers>
                            <f:formContainers>
                                <f:FormContainer >
                                    <f:formElements>
                                        <f:FormElement label="First name">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/NAME_FIRST}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="Last Name">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/NAME_LAST}"/>
                                            </f:fields>
                                        </f:FormElement>
                                    </f:formElements>
                                </f:FormContainer >
                            </f:formContainers>
                        </f:Form>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>		
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection titleUppercase="false" title="FI Support Role">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection >
                        <f:Form width="100%">
                            <f:layout>
                                <f:ColumnLayout columnsM="2" columnsL="3" columnsXL="4"/>
                            </f:layout>
                            <f:formContainers>
                                <f:FormContainer >
                                    <f:formElements>
                                        <f:FormElement label="Reconcilitation Amount">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/RECONCILIATION_ACCOUNT}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="Sort Key">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/SORT_KEY}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="Payment Method">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/PAYMENT_METHOD}"/>
                                            </f:fields>
                                        </f:FormElement>
                                    </f:formElements>
                                </f:FormContainer >
                            </f:formContainers>
                            <f:formContainers>
                                <f:FormContainer >
                                    <f:formElements>
                                        <f:FormElement label="House Bank">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/HOUSE_BANK}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="Terms of Payment">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/PAYMENT_TERMS}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="Reference">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/DUPLICATE_INVOICE_CHECK}"/>
                                            </f:fields>
                                        </f:FormElement>
                                    </f:formElements>
                                </f:FormContainer >
                            </f:formContainers>
                            <f:formContainers>
                                <f:FormContainer >
                                    <f:formElements>
                                        <f:FormElement label="Payee in Document">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/ALTERNATE_PAYEE}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="Block Supplieer">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/BUSINESSPARTNERISBLOCKED}"/>
                                            </f:fields>
                                        </f:FormElement>
                                    </f:formElements>
                                </f:FormContainer >
                            </f:formContainers>
                        </f:Form>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection titleUppercase="false" title="Grantor Information">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection >
                        <f:Form width="100%">
                            <f:layout>
                                <f:ColumnLayout columnsM="2" columnsL="3" columnsXL="4"/>
                            </f:layout>
                            <f:formContainers>
                                <f:FormContainer >
                                    <f:formElements>
                                        <f:FormElement label="Grant Type">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/GRANT_TYPE}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="Validity From">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/VALIDITY_FROM}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="Sales Organisation">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/SALES_ORG}"/>
                                            </f:fields>
                                        </f:FormElement>
                                    </f:formElements>
                                </f:FormContainer >
                            </f:formContainers>
                            <f:formContainers>
                                <f:FormContainer >
                                    <f:formElements>
                                        <f:FormElement label="Distribution Channel">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/DISTRIBUTION_CHANNEL}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="Division">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/DIVISION}"/>
                                            </f:fields>
                                        </f:FormElement>
                                    </f:formElements>
                                </f:FormContainer >
                            </f:formContainers>
                            <f:formContainers>
                                <f:FormContainer >
                                    <f:formElements>
                                        <f:FormElement label="Customer Pricing Procedure">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/CUSTOMER_PRICING_PROCEDURE}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement label="Billing Currency">
                                            <f:fields>
                                                <Text text="{oBPDetailsModel>/ZBPCT/BILLING_CURRENCY}"/>
                                            </f:fields>
                                        </f:FormElement>
                                    </f:formElements>
                                </f:FormContainer >
                            </f:formContainers>
                        </f:Form>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection title="Customer Information" titleUppercase="false">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection >
                        <f:SimpleForm editable="false" layout="ColumnLayout" 
                            columnsXL="4"
                            columnsL="3"
                            columnsM="2">
                            <f:content>
                                <core:Title ></core:Title>
                                <Label text="Recocilitation Amount" />
                                <Text text="{oBPDetailsModel>/ZBPCT/RECONCILIATION_ACCOUNT_CUST}" />
                                <Label text="Sort Key" />
                                <Text text="{oBPDetailsModel>/ZBPCT/SORT_KEY}" />
                                <Label text="Payment Method" />
                                <Text text="{oBPDetailsModel>/ZBPCT/PAYMENT_METHOD}" />
                                <Label text="Terms of Payment" />
                                <Text text="{oBPDetailsModel>/ZBPCT/PAYMENT_TERMS_CUST}" />
                                <core:Title ></core:Title>
                                <Label text="Dunning Area" />
                                <Text text="{oBPDetailsModel>/ZBPCT/DUNNING_AREA}" />
                                <Label text="Dunning Procedure" />
                                <Text text="{oBPDetailsModel>/ZBPCT/DUNNING_PROCEDURE}" />
                                <Label text="Dunning Block" />
                                <Text text="{oBPDetailsModel>/ZBPCT/DUNNING_BLOCK}" />
                                <Label text="Credit Segment" />
                                <Text text="{oBPDetailsModel>/ZBPCT/CREDIT_SEGMENT}" />
                                <core:Title ></core:Title>
                                <Label text="Risk Class" />
                                <Text text="{oBPDetailsModel>/ZBPCT/RISK_CLASS}" />
                                <Label text="Rule" />
                                <Text text="{oBPDetailsModel>/ZBPCT/RULES}" />
                                <Label text="" />
                                <Text text="{oBPDetailsModel>/ZBPCT/Name}" />
                                <Label text="Credit Limit" />
                                <Text text="{oBPDetailsModel>/ZBPCT/CREDIT_LIMIT}" />
                                <Label text="Block Customer" />
                                <Text text="{oBPDetailsModel>/ZBPCT/BLOCK_CUSTOMER}" />
                            </f:content>
                    </f:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection titleUppercase="false" title="Addresses">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection >
                        <Table id="idAddress"
                            inset="false"
                            mode="MultiSelect"
                            items="{oBPDetailsModel>/ADDRESS}">
                            
                            <columns>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Title" />
                                </Column>
                                 <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Name" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Name 2" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Tax Number" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Search Term 2" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Street" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="House Number" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Postal Code" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Region" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="City" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Country" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Language" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Telephone" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Mobile" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Email" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="PO Box" />
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem vAlign="Middle">
                                    <cells>
                                        <Text text="{oBPDetailsModel>TITLE}"/>
                                        <Text text="{oBPDetailsModel>NAME}"/>
                                        <Text text="{oBPDetailsModel>NAME_2}" />
                                        <Text text="{oBPDetailsModel>TAX_REGISTRATION_NUMBER}" />
                                        <Text text="{oBPDetailsModel>SEARCH_TERM_2}" />
                                        <Text text="{oBPDetailsModel>STREET1}" />
                                        <Text text="{oBPDetailsModel>HOUSE_NUMBER}" />
                                        <Text text="{oBPDetailsModel>POSTAL_CODE}" />
                                        <Text text="{oBPDetailsModel>CITY}" />
                                        <Text text="{oBPDetailsModel>COUNTRY_CODE}" />
                                        <Text text="{oBPDetailsModel>LANGUAGE}" />
                                        <Text text="{oBPDetailsModel>TELEPHONE}" />
                                        <Text text="{oBPDetailsModel>MOBILE}" />
                                        <Text text="{oBPDetailsModel>EMAIL}" />
                                        <Text text="{oBPDetailsModel>PO_BOX}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            <uxap:ObjectPageSection titleUppercase="false" title="Payment Information">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection >
                        <Table 
                            inset="false"
                            mode="MultiSelect"
                            items="{oBPDetailsModel>/PAYMENT}">
                            <columns>
                                <Column width="12em">
                                    <Text text="Country/Region" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Bank Number" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Bank Account" />
                                </Column>
                                 <Column minScreenWidth="Tablet" demandPopin="true" >
                                    <Text text="Account Holder" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true" >
                                    <Text text="IBAN" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true" >
                                    <Text text="Reference Details" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true" >
                                    <Text text="Part Bank Type" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true" >
                                    <Text text="Bank Identifier" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true" >
                                    <Text text="Document Currency" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true" >
                                    <Text text="Interm Bank Name" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true" >
                                    <Text text="SWIFT/BIC" />
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem vAlign="Middle">
                                    <cells>
                                        <Text text="{oBPDetailsModel>COUNTRY_KEY}"/>
                                        <Text text="{oBPDetailsModel>BANK_KEY}" />
                                        <Text text="{oBPDetailsModel>BANK_ACCOUNT}" />
                                        <Text text="{oBPDetailsModel>HOLDER_NAME}" />
                                        <Text text="{oBPDetailsModel>IBAN}" />
                                        <Text text="{oBPDetailsModel>REFERENCE_DETAIL}" />
                                        <Text text="{oBPDetailsModel>BANK_TYPE}" />
                                        <Text text="{oBPDetailsModel>BANK_IDENTIFIER}" />
                                        <Text text="{oBPDetailsModel>CURRENCY}" />
                                        <Text text="{oBPDetailsModel>INTERMEDIARY_BANK_NAME}" />
                                        <Text text="{oBPDetailsModel>SWIFT_CODE}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

        </uxap:sections>
    </uxap:ObjectPageLayout>
</core:FragmentDefinition>